<footer class="landing-footer">
  <div class="landing-footer__scene" aria-hidden="true">
    <%= image_tag image_url("landing/footer/footer6.png"), loading: "lazy", alt: "", class: "landing-footer__scene-layer landing-footer__scene-layer--base" %>
    <%= image_tag image_url("landing/footer/footer2.png"), loading: "lazy", alt: "", class: "landing-footer__scene-layer landing-footer__scene-layer--2" %>
    <%= image_tag image_url("landing/footer/footer5.png"), loading: "lazy", alt: "", class: "landing-footer__scene-layer landing-footer__scene-layer--5" %>
    <%= image_tag image_url("landing/footer/footer3.png"), loading: "lazy", alt: "", class: "landing-footer__scene-layer landing-footer__scene-layer--3" %>
    <%= image_tag image_url("landing/footer/footer4.png"), loading: "lazy", alt: "", class: "landing-footer__scene-layer landing-footer__scene-layer--4" %>
    <%= image_tag image_url("landing/footer/footer1.png"), loading: "lazy", alt: "", class: "landing-footer__scene-layer landing-footer__scene-layer--1" %>
  </div>

  <div class="landing-footer__content">
    <div class="landing-footer__info">
      <%= image_tag image_url("landing/header/hack-club-logo.png"), loading: "lazy", alt: "Stardance", class: "landing-footer__logo" %>
      <nav class="landing-footer__links" aria-label="Hack Club links">
        <a href="https://hackclub.com">Hack Club</a>
        <a href="https://hackclub.com/slack/">Slack</a>
        <a href="https://clubs.hackclub.com">Clubs</a>
        <a href="https://hackathons.hackclub.com">Hackathons</a>
      </nav>
    </div>

    <div class="landing-footer__text">
      <p>Hack Club is a 501(c)(3) nonprofit and network of 60k+ technical high schoolers. We believe you learn best by building, so we're creating community and providing grants so you can make awesome projects. In the past few years, we've partnered with GitHub to run Summer of Making, hosted the world's longest hackathon on land, and ran Canada's largest high school hackathon.</p>
      <p>At Hack Club, students aren't just learning, they're shipping.</p>
      <p>Made with &#9829;&#xFE0E; by teenagers, for teenagers at Hack Club</p>
    </div>
  </div>
</footer>
